# Future live broker integrations should read credentials from environment variables.
# Never commit real credentials, API keys, account IDs, tokens, refresh tokens, or passwords.

APP_MODE=paper
MAX_ORDER_DOLLARS=5000
MAX_POSITION_PERCENT=15
REQUIRE_CONFIRMATION_TEXT=CONFIRM

# Schwab Trader API credentials.
# Copy this file to .env and fill in the real values locally.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://secondstate.art/schwab/callback
