# Schwab Trader API credentials.
# Copy this file to .env and fill in real values locally.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://secondstate.art/schwab/callback
SCHWAB_WRITE_SNAPSHOT=true
SCHWAB_ENABLE_LIVE_ORDERS=false
SCHWAB_MAX_LIVE_ORDER_DOLLARS=500

# Shared SEC filing cache.
# Optional: point both machines at the same Google Drive folder, for example:
# SEC_CACHE_DIR=I:/My Drive/PRC/SEC_CACHE
SEC_CACHE_DIR=

# Open Symbol Chat web enrichment.
# Default uses public SEC EDGAR filing/earnings context. Set to "none" to disable
# the built-in provider and show the truthful unavailable state.
SYMBOL_CHAT_WEB_ENRICHMENT_PROVIDER=sec_edgar_public_filings

# OpenAI API settings for AI IPO filing reports.
# Keep the real key local only. Never commit .env.
OPENAI_API_KEY=
OPENAI_IPO_REPORT_MODEL=gpt-5.5

# Hyperliquid read/signed API settings.
# Keep real wallet/API secrets local only. Never commit .env.
HYPE_WALLET_ADDRESS=
HYPE_API_ADDRESS=
HYPE_API_SECRET=
HYPERLIQUID_ENABLE_LIVE_ORDERS=false
HYPERLIQUID_MAX_LIVE_ORDER_DOLLARS=500
